# Qoomlee Airline - Environment Variables
# Copy this file to .env.local and fill in the values.

# Base URL for the app (used for API calls in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database connection (when using a real database)
# DATABASE_URL=postgresql://user:password@host:5432/qoomlee_airline

# Optional: External API for real booking data
# BOOKING_API_URL=https://api.example.com/bookings
# BOOKING_API_KEY=your-api-key-here
